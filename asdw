local btnGuiObj, btnFrame

local function CreateFloatingIcon()
    if btnGuiObj then pcall(function() btnGuiObj:Destroy() end) end
    
    local parent = GetSafeGuiParent()
    local btnSize = 50
    
    btnGuiObj = Instance.new("ScreenGui")
    btnGuiObj.Name = "VOX_Toggle_" .. math.random(100, 999)
    btnGuiObj.ResetOnSpawn   = false
    btnGuiObj.IgnoreGuiInset = true
    btnGuiObj.DisplayOrder   = 9999999
    btnGuiObj.ZIndexBehavior = Enum.ZIndexBehavior.Global
    btnGuiObj.Parent = parent

    btnFrame = Instance.new("Frame")
    btnFrame.Name = "ToggleButtonContainer"
    btnFrame.Size     = UDim2.new(0, btnSize, 0, btnSize)
    btnFrame.Position = UDim2.new(0.5, -25, 0.1, -25)
    btnFrame.BackgroundTransparency = 1
    btnFrame.Parent = btnGuiObj

    local btnImg = Instance.new("ImageButton")
    btnImg.Name = "ToggleButton"
    btnImg.Parent = btnFrame
    btnImg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    btnImg.BackgroundTransparency = 0
    btnImg.AnchorPoint = Vector2.new(0.5, 0.5)
    btnImg.Position = UDim2.new(0.5, 0, 0.5, 0)
    btnImg.Size = UDim2.new(1, 0, 1, 0)
    btnImg.Image = "rbxassetid://86949082023913"
    btnImg.ZIndex = 100
    Instance.new("UICorner", btnImg).CornerRadius = UDim.new(1, 0)

    local isDragging = false
    local dragStartPos = nil
    local frameStartPos = nil
    local hasMoved = false

    btnImg.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            hasMoved = false
            dragStartPos = input.Position
            frameStartPos = btnFrame.Position

            TweenService:Create(btnImg, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                Size = UDim2.new(0.8, 0, 0.8, 0)
            }):Play()
        end
    end)

    UIS.InputChanged:Connect(function(input)
        if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStartPos
            if delta.Magnitude > 5 then 
                hasMoved = true
                btnFrame.Position = UDim2.new(
                    frameStartPos.X.Scale, frameStartPos.X.Offset + delta.X, 
                    frameStartPos.Y.Scale, frameStartPos.Y.Offset + delta.Y
                )
            end
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            if isDragging then
                isDragging = false

                TweenService:Create(btnImg, TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                    Size = UDim2.new(1, 0, 1, 0)
                }):Play()

                if not hasMoved then
                    if type(toggleWindow) == "function" then
                        toggleWindow()
                    end
                end
                hasMoved = false
            end
        end
    end)

    task.spawn(function()
        while btnGuiObj and btnGuiObj.Parent do
            btnGuiObj.Enabled = true
            task.wait(1)
        end
    end)
end

UIS.InputBegan:Connect(function(i, g)
