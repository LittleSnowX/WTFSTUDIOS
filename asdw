                        for _, r in ipairs(raritiesTracker) do
                            local trackKey = targetWorldForQuest .. "_" .. r
                            local framePath = PlayerGui.Main.Frames:FindFirstChild(targetWorldForQuest .. "Quest")
                            local realAmount = 0
                            if framePath and framePath.Container.Frame:FindFirstChild(r) then
                                local amountLabel = framePath.Container.Frame[r].Unit:FindFirstChild("Amount")
                                if amountLabel then
                                    local strAmount = string.match(amountLabel.Text, "^(%d+)") or string.match(amountLabel.Text, "(%d+)")
                                    realAmount = tonumber(strAmount) or 0
                                    if not TrackedKills[trackKey] then TrackedKills[trackKey] = realAmount end
                                    if framePath:GetAttribute("Open") == true or framePath.Visible then
                                        TrackedKills[trackKey] = realAmount
                                    elseif realAmount > TrackedKills[trackKey] then
                                        TrackedKills[trackKey] = realAmount
                                    end
                                end
                            end
                            
                            local currentAmount = TrackedKills[trackKey] or 0
                            local needed = WorldQuestData[targetWorldForQuest][r].Needed
                            if currentAmount < needed then
                                activeRarity = r
                                break
                            else
                                Remotes:WaitForChild("ClaimWorldQuest"):FireServer(targetWorldForQuest, r)
                            end
                        end
                        
                        if activeRarity then
                            local trackKey = targetWorldForQuest .. "_" .. activeRarity
                            local targetPetName = WorldQuestData[targetWorldForQuest][activeRarity].Pet
                            local needed = WorldQuestData[targetWorldForQuest][activeRarity].Needed
                            local currentAmount = TrackedKills[trackKey] or 0
                            
                            if monsterLbl and statLbl and barFill then
                                monsterLbl.Text = "Target: " .. tostring(targetPetName) .. " (" .. activeRarity .. ")"
                                local remain = needed - currentAmount
                                if remain < 0 then remain = 0 end
                                statLbl.Text = currentAmount .. " / " .. needed .. " (Left: " .. remain .. ")"
                                
                                local pct = math.clamp(currentAmount / needed, 0, 1)
                                TweenService:Create(barFill, TweenInfo.new(0.3, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Size = UDim2.new(pct, 0, 1, 0)}):Play()
