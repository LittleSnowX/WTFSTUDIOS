    local function RefreshMonsters()
        isRefreshing = true 
        
        monsterPopup.Options = {"Scanning Map..."}
        monsterPopup.Value = 1
        
        local temp, finalNames = {}, {}
        local enemyFolder = GetActiveEnemyFolder()
        
        if enemyFolder then
            for _, v in ipairs(enemyFolder:GetChildren()) do
                if v:IsA("Model") and not temp[v.Name] then
                    temp[v.Name] = true
                    table.insert(finalNames, v.Name)
                end
            end
        end

        if #finalNames > 0 then
            table.sort(finalNames)
            monsterPopup.Options = finalNames
            
            local savedTarget = Config.SelectedMonster
            local savedIdx = table.find(finalNames, savedTarget)
            
            if savedIdx then
                monsterPopup.Value = savedIdx
                SelectedMonster = savedTarget
            else
                monsterPopup.Value = 1
                SelectedMonster = finalNames[1]
                Config.SelectedMonster = SelectedMonster
                if enemyFolder and enemyFolder.Parent then
                    Config.SelectedFarmWorld = enemyFolder.Parent.Name
                end
                SaveConfig()
            end
        else
            monsterPopup.Options = {"No Map Detected"}
            monsterPopup.Value = 1
            SelectedMonster = ""
        end
        
        isRefreshing = false 
    end

