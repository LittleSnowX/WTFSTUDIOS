                    if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
                        obj.Enabled = false
                        if obj:IsA("ParticleEmitter") then obj:Clear() end
                    end
                end
            end)
            
            if not getgenv().VFXConnections["VFX_Wipe"] then
                getgenv().VFXConnections["VFX_Wipe"] = workspace.DescendantAdded:Connect(function(obj)
                    if not getgenv().DisableVFX then return end
                    
                    if obj:IsA("ParticleEmitter") or obj:IsA("Trail") or obj:IsA("Beam") or obj:IsA("Fire") or obj:IsA("Smoke") or obj:IsA("Sparkles") then
                        task.defer(function()
