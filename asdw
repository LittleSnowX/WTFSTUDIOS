-- TAB: EGG
local tabEgg = secFarm:Tab({ Title = "Egg", Icon = cascade.Symbols.circle })
do
    local HardcodedStars = {
        Star1 = CFrame.new(-127.026, 144.456, 2235.736, 1, 0, 0, 0, 1, 0, 0, 0, 1),
        Star2 = CFrame.new(278.222, 157.859, 4988.032, -0.087, 0, -0.996, 0, 1, 0, 0.996, 0, -0.087),
        Star3 = CFrame.new(-81.528, 135.014, 7572.576, -0.437, 0, -0.9, 0, 1, 0, 0.9, 0, -0.437),
        Star4 = CFrame.new(19.552, 166.409, 10719.408, -0.996, 0, 0.087, 0, 1, 0, -0.087, 0, -0.996),
        Star5 = CFrame.new(-41.351, 152.666, 14056.229, -0.087, 0, -0.996, 0, 1, 0, 0.996, 0, -0.087),
        Star6 = CFrame.new(-235.462, 355.442, 16804.356, -0.996, 0, 0.087, 0, 1, 0, -0.087, 0, -0.996),
    }

    local EggCFrames, starValues = {}, {}
    local function RebuildStarValues()
        local seen = {}
        starValues = {}
        for i = 1, 6 do
            local key = "Star"..i
            if HardcodedStars[key] then
                EggCFrames[key] = HardcodedStars[key]
                table.insert(starValues, key)
                seen[key] = true
            end
        end
        if workspace:FindFirstChild("Stars") then
            for index, star in ipairs(workspace.Stars:GetChildren()) do
                local n = "Star"..index
                if not seen[n] then
                    local cf
                    if star:IsA("Model") and star.PrimaryPart then cf = star.PrimaryPart.CFrame
                    elseif star:IsA("BasePart") then cf = star.CFrame
                    elseif star:FindFirstChild("HumanoidRootPart") then cf = star.HumanoidRootPart.CFrame
                    elseif star:IsA("Model") then 
                        local pt = star:FindFirstChildWhichIsA("BasePart")
                        if pt then cf = pt.CFrame end 
                    end
                    if cf then 
                        EggCFrames[n] = cf
                        table.insert(starValues, n)
                        seen[n] = true 
                    end
                end
            end
        end
    end
    RebuildStarValues()

    local SelectedHatchStar = (Config.SelectedHatchStar and table.find(starValues, Config.SelectedHatchStar)) and Config.SelectedHatchStar or starValues[1]
    local SelectedHatchAmount = Config.SelectedHatchAmount or "Auto"
    local starPopup

    local psSettings = tabEgg:PageSection({ Title = "Star Settings" })
    local fSettings  = psSettings:Form()

    local rowSt = fSettings:Row()
    rowSt:Left():TitleStack({ Title = "Select Star", Subtitle = "Choose which star to hatch eggs from" })
    starPopup = rowSt:Right():PopUpButton({ 
        Options = starValues, 
        Value = table.find(starValues, SelectedHatchStar) or 1,
        ValueChanged = function(self, idx)
            SelectedHatchStar = starValues[idx]
            Config.SelectedHatchStar = SelectedHatchStar
            SaveConfig()
        end 
    })

    local rowRefStar = fSettings:Row()
    rowRefStar:Left():TitleStack({ Title = "Refresh Stars" })
    rowRefStar:Right():Button({ 
        Label = "Refresh", 
        Pushed = function()
            RebuildStarValues()
            if #starValues > 0 then 
                starPopup.Options = starValues
                starPopup.Value = 1
                SelectedHatchStar = starValues[1] 
            end
        end 
    })

    local psAuto = tabEgg:PageSection({ Title = "Automation" })
    local fAuto  = psAuto:Form()

    local rowAE = fAuto:Row()
    rowAE:Left():TitleStack({ Title = "Auto Hatch Eggs" })
    local togAE = rowAE:Right():Toggle({
        Value = cfgBool("AutoEgg"),
        ValueChanged = function(self, val)
            getgenv().AutoEgg = val; SaveToggle("AutoEgg", val)
            if not val then return end
            task.spawn(function()
                local lastWorldUsed = nil
                while getgenv().AutoEgg do
                    pcall(function()
                        local starId = string.match(SelectedHatchStar,"%d+") or "1"
                        local currentWS = "World"..starId
                        
                        if lastWorldUsed ~= currentWS then
                            lastWorldUsed = currentWS
                        end
                        SmartTeleport(currentWS, 4)

                        local pc = LocalPlayer.Character
                        if pc and pc:FindFirstChild("HumanoidRootPart") then
                            local hrp = pc.HumanoidRootPart
                            local cf = EggCFrames[SelectedHatchStar]
                            if cf then 
                                local tp = (cf * CFrame.new(0, 0, 4.5)).Position
                                if (hrp.Position - tp).Magnitude > 3 then 
                                    hrp.CFrame = CFrame.new(tp, tp + hrp.CFrame.LookVector) 
                                end 
                            end
                        end
                        
                        local amt = 1
                        if tostring(SelectedHatchAmount):lower() == "auto" then
                            pcall(function()
                                local lbl = PlayerGui.PetEgg.Egg.Buttons.R:FindFirstChild("ButtonName")
                                if lbl then 
                                    local n = string.match(lbl.Text,"%d+")
                                    if n then amt = tonumber(n) end 
                                end
                            end)
                        else 
                            amt = tonumber(SelectedHatchAmount) or 1 
                        end
                        
                        Remotes:WaitForChild("Eggs"):WaitForChild("Hatch"):InvokeServer(SelectedHatchStar, amt)
                    end)
                    task.wait(0.1)
                end
            end)
        end,
    })
    ToggleRefs["AutoEgg"] = togAE
end

