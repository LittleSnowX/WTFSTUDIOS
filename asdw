local function ScanAllWorlds()
    local worlds = {}
    for _, wf in ipairs(workspace:GetChildren()) do
        if wf.Name:match("^World%d+$") and wf:FindFirstChild("Enemy") then
            table.insert(worlds, wf.Name)
        end
    end
    table.sort(worlds, function(a, b)
        return tonumber(a:match("%d+")) < tonumber(b:match("%d+"))
    end)
    return worlds
end

local function IsInWorld(worldName)
    local wf = workspace:FindFirstChild(worldName)
    if wf then
        if worldName:match("^World%d+$") then
            return wf:FindFirstChild("Map") ~= nil
        else
            return true
        end
    end
    return false
end

local function SmartTeleport(worldName, waitTime, force)
    if force or not IsInWorld(worldName) then
        pcall(function() 
            Remotes:WaitForChild("Teleport"):FireServer(worldName) 
        end)
        task.wait(waitTime or 4)
    end
end

