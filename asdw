    pill.Name = "Pill"
    pill.BackgroundColor3 = Color3.fromRGB(20, 20, 22)
    pill.BackgroundTransparency = 0.1
    pill.BorderSizePixel = 0
    pill.Size = UDim2.new(0, 0, 0, 36)
    pill.ClipsDescendants = true
    pill.Parent = container

