local tabRaid = secFarm:Tab({ Title = "Raid", Icon = cascade.Symbols.shield })
do
    local LeaveAtWave = tonumber(Config.LeaveAtWave) or 20
    local EasterLeaveAtWave = tonumber(Config.EasterLeaveAtWave) or 1000
    
    local RaidPaused  = false
    local RaidSaved   = {}

    local function GetWave()
        local ok, r = pcall(function()
            local lbl = PlayerGui.Main.HUD.Dungeon.RaidsInfo.WavesFrame.Wave
            local ct = lbl:FindFirstChild("ContentText") or lbl
            return tonumber(string.match(ct.Text or ct.ContentText, "(%d+)%s*/"))
        end)
        return ok and r or nil
    end
    
    local function InDungeon()
        local ok, r = pcall(function() return PlayerGui.Main.HUD.Dungeon.Visible end)
        return ok and r
    end

    local function InEaster()
        local er = workspace:FindFirstChild("EasterRaid")
        local pc = LocalPlayer.Character
        local hrp = pc and pc:FindFirstChild("HumanoidRootPart")
        if er and hrp then
            local refPart = er:FindFirstChildWhichIsA("BasePart", true)
            if refPart then
                if (hrp.Position - refPart.Position).Magnitude < 5000 then
                    return true
                end
            end
        end
        return false
    end

    local function isAliveFast(targetPart)
        if not targetPart or not targetPart.Parent then return false end
        local m = targetPart:FindFirstAncestorOfClass("Model")
        if not m then return false end
        local h = m:FindFirstChildOfClass("Humanoid")
        return h and h.Health > 0
    end

    local function FindAggressiveEnemy(folder, maxDist)
        local pc = LocalPlayer.Character
        local hrp = pc and pc:FindFirstChild("HumanoidRootPart")
        if not hrp then return nil end
        
        local best, bd = nil, maxDist or 50000
        if not folder then return nil end

        for _, obj in ipairs(folder:GetDescendants()) do
            if obj:IsA("Model") and obj ~= pc then
                local hum = obj:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    local targetPart = obj:FindFirstChild("HumanoidRootPart") or obj.PrimaryPart
                    if targetPart then
                        local d = (hrp.Position - targetPart.Position).Magnitude
                        if d < bd then
                            bd = d
                            best = targetPart
                        end
                    end
                end
            end
        end
        return best
    end

    local function ExitDungeon()
        pcall(function() Remotes:WaitForChild("LeaveRaid"):FireServer() end)
    end
    
    local function PauseFarms()
        if RaidPaused then return end; RaidPaused = true
        RaidSaved = {AutoTeleport = getgenv().AutoTeleport, AutoWorldQuest = getgenv().AutoWorldQuest, AutoEgg = getgenv().AutoEgg}
        for k, _ in pairs(RaidSaved) do 
            if getgenv()[k] then 
                getgenv()[k] = false; pcall(function() ToggleRefs[k].Value = false end) 
            end 
        end
    end
    
    local function ResumeFarms()
        if not RaidPaused then return end; RaidPaused = false
