-- AUTO REJOIN SYSTEM
task.spawn(function()
    local TeleportService = TeleportService

    local function doRejoin()
        if getgenv().AutoRejoinEnabled then
            task.wait(5)
            pcall(function()
                TeleportService:Teleport(game.PlaceId, Players.LocalPlayer)
            end)
        end
    end

    GuiService.ErrorMessageChanged:Connect(function()
        doRejoin()
    end)

    pcall(function()
        local promptGui = CoreGui:FindFirstChild("RobloxPromptGui")
        if promptGui then
            local promptOverlay = promptGui:FindFirstChild("promptOverlay")
            if promptOverlay then
                promptOverlay.ChildAdded:Connect(function(child)
                    if child.Name == "ErrorPrompt" then
                        doRejoin()
                    end
                end)
            end
        end
    end)
end)

-- ANTI AFK 
getgenv().AntiAFK = true

task.spawn(function()
    local VirtualInputManager = game:GetService("VirtualInputManager")

    LocalPlayer.Idled:Connect(function()
        if getgenv().AntiAFK then
            pcall(function()
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
            end)
        end
    end)

    task.spawn(function()
        while true do
            task.wait(2.5)
            if getgenv().AntiAFK then
                pcall(function()
                    if remotes and remotes:FindFirstChild("Clicked") then
                        remotes.Clicked:FireServer()
                    end
                end)
            end
        end
    end)

    pcall(function()
        if remotes then
            local requestAfk = remotes:FindFirstChild("RequestAfkRestore")
            local cancelAfk = remotes:FindFirstChild("CancelAfkRestore")
            
            if requestAfk and requestAfk:IsA("RemoteEvent") then
                requestAfk.OnClientEvent:Connect(function()
                    if getgenv().AntiAFK and cancelAfk then
                        task.wait(math.random(1, 3))
                        cancelAfk:FireServer()
                    end
                end)
            end
        end
    end)
end)

