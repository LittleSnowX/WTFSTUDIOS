    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(45, 45, 50)
    stroke.Thickness = 1.5
    stroke.Parent = pill

    local brandLogo = Instance.new("ImageLabel")
    brandLogo.Name = "BrandLogo"
    brandLogo.Size = UDim2.new(0, 28, 0, 28)
    brandLogo.Position = UDim2.new(0, 8, 0.5, -14)
    brandLogo.BackgroundTransparency = 1
    brandLogo.Image = logoId
    brandLogo.ImageTransparency = 0.2
    brandLogo.Parent = pill

    local statusLabel = nil
    if iconId then
        statusLabel = Instance.new("TextLabel")
        statusLabel.Name = "StatusEmoji"
        statusLabel.Size = UDim2.new(0, 20, 0, 20)
        statusLabel.Position = UDim2.new(1, -30, 0.5, 0)
        statusLabel.AnchorPoint = Vector2.new(0, 0.5)
        statusLabel.BackgroundTransparency = 1
        statusLabel.Text = (tostring(iconId):find("131922379895080") and "❌") or "✅"
        statusLabel.TextSize = 16
        statusLabel.Parent = pill
    end

    local text = Instance.new("TextLabel")
    text.Name = "Text"
    text.Size = UDim2.new(1, (statusLabel and -81 or -51), 1, 0)
    text.Position = UDim2.new(0, 44, 0.5, 0)
    text.AnchorPoint = Vector2.new(0, 0.5)
    text.BackgroundTransparency = 1
    text.Font = Enum.Font.GothamMedium
    text.Text = content ~= "" and content or title
    text.TextColor3 = Color3.fromRGB(255, 255, 255)
    text.TextSize = 14
    text.TextXAlignment = Enum.TextXAlignment.Left
    text.Parent = pill

    local textSizeX = 200
    pcall(function()
        local result = TextService:GetTextSize(text.Text, text.TextSize, text.Font, Vector2.new(1000, 36))
        if result then textSizeX = result.X end
    end)
    local targetWidth = textSizeX + (statusLabel and 81 or 51)

    local ts = TweenService
    ts:Create(pill, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Size = UDim2.new(0, targetWidth, 0, 36)}):Play()
    
    task.spawn(function()
        task.wait(duration)
        local tOut = TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.In)
        ts:Create(pill, tOut, {Size = UDim2.new(0, 0, 0, 36), BackgroundTransparency = 1}):Play()
        ts:Create(text, tOut, {TextTransparency = 1}):Play()
        ts:Create(brandLogo, tOut, {ImageTransparency = 1}):Play()
        if statusLabel then ts:Create(statusLabel, tOut, {TextTransparency = 1}):Play() end
        task.wait(0.5)
        pill:Destroy()
    end)
end

